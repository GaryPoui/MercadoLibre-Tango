# Base de datos PostgreSQL
DB_USER=postgres
DB_PASS=tu_password

# MercadoLibre - Obtener en: https://developers.mercadolibre.com.ar/
ML_CLIENT_ID=tu_client_id
ML_CLIENT_SECRET=tu_client_secret
ML_WEBHOOK_SECRET=tu_webhook_secret
ML_SELLER_ID=tu_seller_id

# Tango Nexo API
TANGO_API_URL=https://api.tango.com.ar
TANGO_API_KEY=tu_api_key
TANGO_EMPRESA=tu_empresa

# Google Sheets - ID del spreadsheet de la URL
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SHEETS_ID=tu_spreadsheet_id
# El archivo credentials.json de Google Service Account va en src/main/resources/

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Notificaciones por email
NOTIFICATION_EMAIL=tu@email.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu@gmail.com
MAIL_PASSWORD=tu_app_password  # Usar "App Password" de Google, no la contraseña real

# Notificación por webhook (Slack, Discord, etc.) - opcional
NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...
